{
  "version": 1,
  "source": "dofusdb",
  "entity": "spell",
  "label": "Sorts",
  "meta": {
    "notes": "DofusDB : spell + spell-levels (plusieurs niveaux). Les paramètres globaux sont lus depuis spell_global, construit par SpellGlobalNormalizer (spell racine + levels[0] + area = premier effet). Mapping uniquement paramètres globaux ; les effets sont traités par SpellEffectsConversionService."
  },
  "endpoints": {
    "fetchOne": {
      "pathTemplate": "/spells/{id}",
      "method": "GET",
      "queryDefaults": { "lang": "fr" }
    },
    "fetchMany": {
      "path": "/spells",
      "method": "GET",
      "queryDefaults": { "lang": "fr", "$limit": 50, "$skip": 0 }
    }
  },
  "filters": {
    "supported": [
      { "key": "id", "type": "number" },
      { "key": "idMin", "type": "number" },
      { "key": "idMax", "type": "number" },
      { "key": "name", "type": "string" },
      { "key": "breedId", "type": "number" }
    ]
  },
  "target": {
    "krosmozEntity": "spell",
    "primaryKey": { "sourceField": "id", "targetField": "dofusdb_id" },
    "autoUpdateField": "auto_update"
  },
  "mapping": [
    { "key": "dofusdb_id", "from": { "path": "spell_global.id" }, "to": [{ "model": "spells", "field": "dofusdb_id" }], "formatters": [{ "name": "toString", "args": {} }] },
    { "key": "name", "from": { "path": "spell_global.name", "langAware": true }, "to": [{ "model": "spells", "field": "name" }], "formatters": [{ "name": "pickLang", "args": { "lang": "fr", "fallback": "fr" } }] },
    { "key": "description", "from": { "path": "spell_global.description", "langAware": true }, "to": [{ "model": "spells", "field": "description" }], "formatters": [{ "name": "pickLang", "args": { "lang": "fr", "fallback": "fr" } }] },
    { "key": "image", "from": { "path": "spell_global.img" }, "to": [{ "model": "spells", "field": "image" }], "formatters": [{ "name": "storeScrappedImage", "args": { "entityFolder": "spells", "idPath": "id" } }] },
    { "key": "pa", "from": { "path": "spell_global.apCost" }, "to": [{ "model": "spells", "field": "pa" }], "formatters": [{ "name": "toInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "pa" } }] },
    { "key": "spell_po_min", "from": { "path": "spell_global.minRange" }, "to": [{ "model": "spells", "field": "spell_po_min" }], "formatters": [{ "name": "nullableInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "spell_range_min_spell" } }, { "name": "toString", "args": {} }] },
    { "key": "spell_po_max", "from": { "path": "spell_global.range" }, "to": [{ "model": "spells", "field": "spell_po_max" }], "formatters": [{ "name": "nullableInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "spell_range_max_spell" } }, { "name": "toString", "args": {} }] },
    { "key": "level", "from": { "path": "spell_global.grade" }, "to": [{ "model": "spells", "field": "level" }], "formatters": [{ "name": "toInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "level" } }, { "name": "toString", "args": {} }] },
    { "key": "cast_per_turn", "from": { "path": "spell_global.maxCastPerTurn" }, "to": [{ "model": "spells", "field": "cast_per_turn" }], "formatters": [{ "name": "toInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "cast_per_turn" } }, { "name": "toString", "args": {} }] },
    { "key": "cast_per_target", "from": { "path": "spell_global.maxCastPerTarget" }, "to": [{ "model": "spells", "field": "cast_per_target" }], "formatters": [{ "name": "nullableInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "cast_per_target" } }, { "name": "toString", "args": {} }] },
    { "key": "sight_line", "from": { "path": "spell_global.castTestLos" }, "to": [{ "model": "spells", "field": "sight_line" }], "formatters": [{ "name": "toInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "sight_line" } }] },
    { "key": "element", "from": { "path": "spell_global.elementId" }, "to": [{ "model": "spells", "field": "element" }], "formatters": [{ "name": "nullableInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "element" } }] },
    { "key": "category", "from": { "path": "spell_global.categoryId" }, "to": [{ "model": "spells", "field": "category" }], "formatters": [{ "name": "nullableInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "category" } }] },
    { "key": "area", "from": { "path": "spell_global.area" }, "to": [{ "model": "spells", "field": "area" }], "formatters": [{ "name": "zoneDescrToNotation", "args": {} }, { "name": "toString", "args": {} }] },
    { "key": "po_editable", "from": { "path": "spell_global.rangeCanBeBoosted" }, "to": [{ "model": "spells", "field": "po_editable" }], "formatters": [{ "name": "toInt", "args": {} }, { "name": "clampToCharacteristic", "args": { "characteristicId": "po_editable" } }] }
  ],
  "_mappingUnused": [
    { "key": "number_between_two_cast", "from": { "path": "spell_global.minCastInterval" }, "to": [{ "model": "spells", "field": "number_between_two_cast" }] },
    { "key": "number_between_two_cast_editable", "from": { "path": "spell_global.minCastIntervalEditable" }, "to": [{ "model": "spells", "field": "number_between_two_cast_editable" }] },
    { "key": "is_magic", "from": { "path": "spell_global.isMagic" }, "to": [{ "model": "spells", "field": "is_magic" }] },
    { "key": "powerful", "from": { "path": "spell_global.powerful" }, "to": [{ "model": "spells", "field": "powerful" }] }
  ]
}
